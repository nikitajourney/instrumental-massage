# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- NOTIFICATION SETTINGS ---
# Telegram Bot integration
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# VK community messages integration. Keep these only on backend hosting.
VK_ACCESS_TOKEN=""
VK_PEER_ID=""
VK_API_VERSION="5.199"

# Email SMTP Server (e.g. Yandex, Mail.ru, Google)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_TO=""

# Public static-site lead settings. VITE_* values are bundled into the browser build.
# Do not put bot tokens or passwords in VITE_* variables.
VITE_LEAD_EMAIL="academia.massage@yandex.ru"
VITE_LEAD_API_URL=""
